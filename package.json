{
  "name": "gamehive",
  "private": true,
  "workspaces": [
    "apps/web/frontend",
    "apps/backend"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:web": "npm run dev -w gamehive",
    "dev:backend": "npm run dev -w @gamehive/backend",
    "dev:both": "concurrently \"npm run dev:web\" \"npm run dev:backend\""
  }
}
